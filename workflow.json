        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 4096,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"document\",\n          \"source\": {\n            \"type\": \"base64\",\n            \"media_type\": \"{{ $json.mime_type }}\",\n            \"data\": \"{{ $json.base64_data }}\"\n          }\n        },\n        {\n          \"type\": \"text\",\n          \"text\": \"You are an expert insurance claims analyst specializing in French automobile accident reports. Analyze this Constat Amiable and extract all data into a structured JSON. Respond ONLY with valid JSON, no markdown, no backticks. Use this schema: {accident: {date, time, location: {country, city, street}}, injuries: {declared: bool, details}, vehicle_a: {driver: {last_name, first_name, address, phone, license_number, license_date}, insurance: {company, policy_number, green_card_number, validity_period}, vehicle: {make_model, plate_number}, damages, signature_present: bool}, vehicle_b: {same structure as vehicle_a}, circumstances: {vehicle_a: [list], vehicle_b: [list]}, completeness: {is_complete: bool, missing_fields: [list]}, classification: {severity: minor|moderate|severe, has_injuries: bool, route: AUTO_PROCESS|REVIEW_NEEDED|URGENT_ESCALATION, route_reason: string}}. Rules: null for missing fields. URGENT_ESCALATION if injuries. REVIEW_NEEDED if incomplete. AUTO_PROCESS if complete and no injuries. Preserve original French text in values.\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
