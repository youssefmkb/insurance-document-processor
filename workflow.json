        "jsCode": "const response = $input.first().json;\nconst text = response.content[0].text;\n\n// Clean potential markdown backticks\nconst clean = text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\nconst parsed = JSON.parse(clean);\n\nreturn [{\n  json: parsed\n}];"
      },
