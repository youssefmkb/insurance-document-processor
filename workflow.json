      "parameters": {
        "jsCode": "const binaryKey = Object.keys($input.first().binary)[0];\nconst buffer = await this.helpers.getBinaryDataBuffer(0, binaryKey);\nconst base64 = buffer.toString('base64');\nconst mimeType = $input.first().binary[binaryKey].mimeType;\n\nreturn [{\n  json: {\n    base64_data: base64,\n    mime_type: mimeType\n  }\n}];"
      },
